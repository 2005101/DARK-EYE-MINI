import fetch from 'node-fetch'
export default {
  name: 'mediafire',
  desc: 'Download Mediafire',
  execute: async(sock, m, args) => {
    const url = args[0]
    if(!url) return sock.sendMessage(m.key.remoteJid, { text: 'Usage:!mediafire https://mediafire.com/...' }, { quoted: m })
    const api = `https://api.dreaded.in/api/mediafire?url=${url}`
    const res = await fetch(api)
    const data = await res.json()
    await sock.sendMessage(m.key.remoteJid, { document: { url: data.result.link }, fileName: data.result.name }, { quoted: m })
  }
}

